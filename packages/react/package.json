{
  "name": "@design-system-toolkit/react",
  "version": "0.1.2",
  "description": "Config-driven React renderer for design-system audits. Pairs with @design-system-toolkit/core.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=esm --outfile=dist/index.js --jsx=automatic --external:react --external:react-dom --external:react/jsx-runtime --external:@design-system-toolkit/core",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@design-system-toolkit/core": "^0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erikparr/design-system-toolkit.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/erikparr/design-system-toolkit#readme",
  "bugs": "https://github.com/erikparr/design-system-toolkit/issues"
}
