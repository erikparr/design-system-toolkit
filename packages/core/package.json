{
  "name": "@agentic-design-audit/core",
  "version": "0.1.0",
  "description": "Framework-pure engine for design-system auditing: normalized token model, WCAG contrast, drift diff, and a browser code adapter.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./adapters/code": "./dist/adapters/code.js"
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.js src/adapters/code.js --bundle --format=esm --platform=neutral --outdir=dist",
    "prepack": "npm run build"
  }
}
